<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="IllUsionVPN.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0D1221" Offset="0" />
                <GradientStop Color="#05080F" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="28" Width="420">
            <TextBlock Text="IllUsion" FontSize="40" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" />

            <!-- Кнопка подключения -->
            <Button x:Name="ConnectButton" Click="ConnectButton_Click"
                    Width="200" Height="200" CornerRadius="100"
                    HorizontalAlignment="Center" BorderThickness="0">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
                        <GradientStop Color="{StaticResource AccentSecondaryColor}" Offset="1" />
                    </LinearGradientBrush>
                </Button.Background>
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <FontIcon Glyph="&#xE72E;" FontSize="48" Foreground="White" />
                    <TextBlock x:Name="ConnectLabel" Text="Подключить"
                               Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Border Background="{StaticResource CardBrush}" CornerRadius="24" Padding="16,10"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray" />
                    <TextBlock x:Name="StatusText" Text="Не защищено" Foreground="White" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <!-- Текущий сервер -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="16" Padding="16">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ServerFlag" Grid.Column="0" Text="🌐" FontSize="30" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="ServerCity" Text="Выберите сервер" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock x:Name="ServerCountry" Text="—" Foreground="#99FFFFFF" FontSize="12" />
                    </StackPanel>
                    <TextBlock x:Name="ServerLatency" Grid.Column="2" Text="" Foreground="{StaticResource SuccessBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>
