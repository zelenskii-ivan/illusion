<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="IllUsionVPN.Views.ServersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:IllUsionVPN.Models">

    <Grid Padding="24" RowSpacing="16">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0D1221" Offset="0" />
                <GradientStop Color="#05080F" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Серверы" FontSize="28" FontWeight="Bold" Foreground="White" />
            <Button Content="Самый быстрый" Click="Fastest_Click" VerticalAlignment="Center" />
            <Button Content="Обновить" Click="Refresh_Click" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="ServerList" Grid.Row="1" SelectionMode="Single"
                  SelectionChanged="ServerList_SelectionChanged" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Server">
                    <Grid ColumnSpacing="14" Padding="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Flag}" FontSize="26" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind City}" Foreground="White" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind Country}" Foreground="#99FFFFFF" FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind LatencyLabel}" Foreground="#33D98C"
                                   VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
