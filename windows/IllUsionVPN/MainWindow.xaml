<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="IllUsionVPN.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="IllUsion VPN">

    <Grid>
        <muxc:NavigationView
            x:Name="Nav"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="Nav_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Главная" Tag="home" Icon="Shield" IsSelected="True" />
                <muxc:NavigationViewItem Content="Серверы" Tag="servers" Icon="Globe" />
                <muxc:NavigationViewItem Content="Настройки" Tag="settings" Icon="Setting" />
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Window>
